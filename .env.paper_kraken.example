# Paper trading profile with Kraken market data (no real orders)
# Usage:
#   set -a; source .env.paper_kraken.example; set +a
#   ./.venv/bin/python trading_bot.py

# Kraken API credentials (set these in your shell or copy to a private .env)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Safe paper mode: no real orders, but real exchange connectivity
DRY_RUN=true
SIMULATE_DATA=false

# Keep bot active enough for testing
CHECK_INTERVAL=10
MAX_OPEN_TRADES=3
TRADE_AMOUNT=10
MIN_TRADE_AMOUNT=3
TICKER_BATCH_SIZE=80
TICKER_FETCH_RETRIES=2
TICKER_RETRY_DELAY_SECONDS=1.0

# Strategy defaults
USE_TABULAR_MODEL=true
USE_ML_MODEL=false
TABULAR_MODEL_PATH=./model/catboost_trading_model
TABULAR_MIN_CONFIDENCE=0.45
TABULAR_BLOCK_ON_SELL=true
TABULAR_SELL_BLOCK_MIN_PROBA=0.55
AUTO_TUNE_TABULAR_CONFIDENCE=true
AUTO_TUNE_LOOKBACK_TRADES=200
AUTO_TUNE_THRESHOLD_MIN=0.40
AUTO_TUNE_THRESHOLD_MAX=0.75
AUTO_TUNE_THRESHOLD_STEP=0.01
AUTO_TUNE_MIN_TRADES=10
AUTO_TUNE_MAX_DELTA=0.02
AUTO_TUNE_COOLDOWN_MINUTES=60
AUTO_TUNE_STATE_FILE=auto_tune_state.json

MIN_ENTRY_SCORE=50
ENABLE_FALLBACK_ENTRY=true
ENABLE_SIGNAL_EXITS=true
EXIT_ON_DOWNTREND=true
ENTRY_REQUIRE_PRICE_ABOVE_EMA20=false
FORCE_FILL_SLOTS=true
FORCE_FILL_MIN_SCORE=30
REENTRY_COOLDOWN_SECONDS=900
REENTRY_DYNAMIC_ENABLED=true
REENTRY_COOLDOWN_MIN_SECONDS=300
REENTRY_COOLDOWN_MAX_SECONDS=1200
REENTRY_VOLATILITY_LOW_ATR_PCT=0.008
REENTRY_VOLATILITY_HIGH_ATR_PCT=0.018
REENTRY_COOLDOWN_MULT_LOW_VOL=0.70
REENTRY_COOLDOWN_MULT_MID_VOL=1.00
REENTRY_COOLDOWN_MULT_HIGH_VOL=1.30
MAX_HOLD_SECONDS=300

# Guardrails
MAX_DAILY_LOSS_PCT=1.0
MAX_BUYS_PER_HOUR=8
LOSS_STREAK_PAUSE_THRESHOLD=2
LOSS_STREAK_PAUSE_SECONDS=1800

# Logging
PERFORMANCE_LOG_ENABLED=true
PERFORMANCE_LOG_FILE=trade_journal.csv
PERFORMANCE_REPORT_EVERY=1

# Optional external AI co-pilot
MAMMOUTH_API_KEY=
AI_COPILOT_ENABLED=false
AI_COPILOT_API_URL=https://api.mammouth.ai/v1/chat/completions
AI_COPILOT_MODEL=gpt-5.4-nano
AI_COPILOT_INTERVAL_MINUTES=62
AI_COPILOT_SHADOW_MODE=true
AI_COPILOT_MAX_CALLS_PER_DAY=24
AI_COPILOT_MAX_CALLS_PER_MONTH=720
AI_COPILOT_MAX_BUDGET_USD_PER_MONTH=5.0
AI_COPILOT_MAX_OUTPUT_TOKENS=300
AI_COPILOT_TEMPERATURE=0.1
AI_COPILOT_MAX_CONSECUTIVE_ERRORS=3
AI_COPILOT_COST_INPUT_PER_MTOK=0.2
AI_COPILOT_COST_OUTPUT_PER_MTOK=1.25
AI_COPILOT_MIN_ENTRY_SCORE_MIN=55
AI_COPILOT_MIN_ENTRY_SCORE_MAX=70
AI_COPILOT_REENTRY_COOLDOWN_MIN=300
AI_COPILOT_REENTRY_COOLDOWN_MAX=1200
AI_COPILOT_TABULAR_BUY_CONF_MIN=0.50
AI_COPILOT_TABULAR_BUY_CONF_MAX=0.65

# AutoResearch optional
AUTORESEARCH_ENABLED=false

# Modular research providers for scripts/fetch_research_signal.py
RESEARCH_PROVIDERS=fng,news
RESEARCH_FNG_WEIGHT=1.0
RESEARCH_NEWS_WEIGHT=0.6
RESEARCH_NEWS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://www.theblock.co/rss.xml
RESEARCH_NEWS_LOOKBACK_HOURS=24
RESEARCH_NEWS_MAX_ITEMS_PER_FEED=30
