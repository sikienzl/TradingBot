{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Trading Bot operational dashboard — scorecard verdict, system health, Pi metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green",  "index": 0, "text": "GO" },
                           "2": { "color": "yellow", "index": 1, "text": "HOLD" },
                           "3": { "color": "red",    "index": 2, "text": "NO-GO" },
                           "4": { "color": "blue",   "index": 3, "text": "MAINTENANCE" } },
              "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red",    "value": 3 }
          ] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Scorecard Verdict",
      "type": "stat",
      "targets": [{ "expr": "trading_scorecard_final_exit_code", "legendFormat": "Verdict", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "red",    "value": 600 }
          ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Metrics Age",
      "type": "stat",
      "targets": [{ "expr": "time() - trading_scorecard_timestamp_seconds", "legendFormat": "Age", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 55 },
            { "color": "red",    "value": 70 }
          ] },
          "unit": "celsius"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "CPU Temperature",
      "type": "stat",
      "targets": [{ "expr": "node_hwmon_temp_celsius{chip=\"thermal_thermal_zone0\",sensor=\"temp0\"}", "legendFormat": "°C", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red",    "value": 90 }
          ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "RAM Used %",
      "type": "stat",
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "RAM %", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU Usage % (all cores)",
      "type": "timeseries",
      "targets": [{
        "expr": "100 - (avg by(cpu)(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU {{cpu}}",
        "refId": "A"
      }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "node_memory_MemTotal_bytes",     "legendFormat": "Total",     "refId": "A" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "celsius" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "CPU Temperature Over Time",
      "type": "timeseries",
      "targets": [{
        "expr": "node_hwmon_temp_celsius{chip=\"thermal_thermal_zone0\",sensor=\"temp0\"}",
        "legendFormat": "Temperature",
        "refId": "A"
      }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Scorecard Verdict History",
      "type": "timeseries",
      "targets": [{
        "expr": "trading_scorecard_final_exit_code",
        "legendFormat": "Exit Code (0=GO 2=HOLD 3=NO-GO)",
        "refId": "A"
      }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "System Load (1m / 15m)",
      "type": "timeseries",
      "targets": [
        { "expr": "node_load1",  "legendFormat": "Load 1m",  "refId": "A" },
        { "expr": "node_load15", "legendFormat": "Load 15m", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "Disk Free (root /)",
      "type": "timeseries",
      "targets": [{
        "expr": "node_filesystem_avail_bytes{mountpoint=\"/\",fstype=\"ext4\"}",
        "legendFormat": "Free on /",
        "refId": "A"
      }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 100 }
          ] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "id": 12,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Closed Trades",
      "type": "stat",
      "targets": [{ "expr": "trading_scorecard_closed_trades", "legendFormat": "Closed", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 45 },
            { "color": "green", "value": 50 }
          ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Win Rate",
      "type": "stat",
      "targets": [{ "expr": "trading_scorecard_win_rate_percent", "legendFormat": "Win Rate", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 1.0 },
            { "color": "green", "value": 1.2 }
          ] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Profit Factor" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "match": "-1", "result": { "color": "green", "text": "inf" } }, "type": "value" }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 28 },
      "id": 14,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Profit Factor",
      "type": "stat",
      "targets": [{ "expr": "trading_scorecard_profit_factor", "legendFormat": "Profit Factor", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 0 }
          ] },
          "unit": "currencyEUR"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 28 },
      "id": 15,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Realized PnL",
      "type": "stat",
      "targets": [{ "expr": "trading_scorecard_realized_pnl", "legendFormat": "PnL", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 15 }
          ] },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 28 },
      "id": 16,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Max Drawdown %",
      "type": "stat",
      "targets": [{ "expr": "trading_scorecard_max_drawdown_pct", "legendFormat": "Max DD %", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 32 },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "name"
      },
      "title": "Primary Fail Reason",
      "type": "stat",
      "targets": [{
        "expr": "trading_scorecard_fail_reason",
        "legendFormat": "{{reason}}",
        "refId": "A"
      }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 17,
      "options": { "legend": { "calcs": ["lastNotNull", "min", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Trading KPI History (%)",
      "type": "timeseries",
      "targets": [
        { "expr": "trading_scorecard_win_rate_percent", "legendFormat": "Win Rate %", "refId": "A" },
        { "expr": "trading_scorecard_max_drawdown_pct", "legendFormat": "Max DD %", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Realized PnL" },
            "properties": [
              { "id": "unit", "value": "currencyEUR" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 18,
      "options": { "legend": { "calcs": ["lastNotNull", "min", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Trading KPI History (Absolute)",
      "type": "timeseries",
      "targets": [
        { "expr": "trading_scorecard_closed_trades", "legendFormat": "Closed Trades", "refId": "A" },
        { "expr": "trading_scorecard_profit_factor", "legendFormat": "Profit Factor", "refId": "B" },
        { "expr": "trading_scorecard_realized_pnl", "legendFormat": "Realized PnL", "refId": "C" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["trading", "pi", "monitoring"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "title": "Trading Bot — Pi Ops",
  "uid": "trading-bot-pi-ops",
  "version": 4
}
