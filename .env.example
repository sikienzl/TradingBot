# Copy this file to .env and adjust values as needed.
# cp .env.example .env

# Exchange credentials (leave empty for simulation-only setup)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Base setup
EXCHANGE_NAME=kraken
BASE_CURRENCY=EUR
EXCLUDED_COINS=USDC,USDT,EURT,DAI,TUSD,USDP,FDUSD,USDE

# Safety/mode
DRY_RUN=true
SIMULATE_DATA=false

# Execution cadence
CHECK_INTERVAL=8
MAX_OPEN_TRADES=4

# Position sizing
TRADE_AMOUNT=10
MIN_TRADE_AMOUNT=3
ALLOW_PARTIAL_TRADES=true
CASH_RESERVE_PCT=0.02

# Market filter
MIN_VOLUME_BASE=100000
TOP_N_FOR_ANALYSIS=12

# Entry logic
MIN_ENTRY_SCORE=50
ENABLE_FALLBACK_ENTRY=true
ENABLE_SIGNAL_EXITS=true
EXIT_ON_DOWNTREND=true
FALLBACK_MIN_SCORE=40
FALLBACK_MAX_RSI=80
FORCE_FILL_SLOTS=true
FORCE_FILL_MIN_SCORE=30

# Exit logic
ATR_STOP_MULT=1.5
ATR_TP_MULT=2.0
MAX_HOLD_SECONDS=300

# Hard risk guardrails (0 disables)
MAX_DAILY_LOSS_PCT=1.5
MAX_BUYS_PER_HOUR=12
LOSS_STREAK_PAUSE_THRESHOLD=3
LOSS_STREAK_PAUSE_SECONDS=1800

# Indicators / timeframe
RSI_PERIOD=14
SMA_PERIOD_SHORT=20
SMA_PERIOD_LONG=50
OHLCV_TIMEFRAME=1h

# Legacy params (currently not used for exit decisions)
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10

# LLM model
USE_ML_MODEL=false
MODEL_PATH=./model/fine_tuned_trading_model
ML_MIN_CONFIDENCE=0.5

# CatBoost model
USE_TABULAR_MODEL=true
TABULAR_MODEL_PATH=./model/catboost_trading_model
TABULAR_MIN_CONFIDENCE=0.55
TABULAR_BLOCK_ON_SELL=true
TABULAR_SELL_BLOCK_MIN_PROBA=0.55
AUTO_TUNE_TABULAR_CONFIDENCE=true
AUTO_TUNE_LOOKBACK_TRADES=200
AUTO_TUNE_THRESHOLD_MIN=0.45
AUTO_TUNE_THRESHOLD_MAX=0.70
AUTO_TUNE_THRESHOLD_STEP=0.01
AUTO_TUNE_MIN_TRADES=3
AUTO_TUNE_MAX_DELTA=0.02
AUTO_TUNE_COOLDOWN_MINUTES=60
AUTO_TUNE_STATE_FILE=auto_tune_state.json

# Performance / trade journal
PERFORMANCE_LOG_ENABLED=true
PERFORMANCE_LOG_FILE=trade_journal.csv
PERFORMANCE_REPORT_EVERY=1
