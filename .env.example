# Copy this file to .env and adjust values as needed.
# cp .env.example .env

# Exchange credentials (leave empty for simulation-only setup)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Base setup
EXCHANGE_NAME=kraken
BASE_CURRENCY=EUR
EXCLUDED_COINS=USDC,USDT,EURT,DAI,TUSD,USDP,FDUSD,USDE

# Safety/mode
DRY_RUN=true
SIMULATE_DATA=false

# Execution cadence
CHECK_INTERVAL=8
MAX_OPEN_TRADES=4

# Position sizing
TRADE_AMOUNT=10
MIN_TRADE_AMOUNT=3
ALLOW_PARTIAL_TRADES=true
CASH_RESERVE_PCT=0.02

# Market filter
MIN_VOLUME_BASE=100000
TOP_N_FOR_ANALYSIS=12
TICKER_BATCH_SIZE=80
TICKER_FETCH_RETRIES=2
TICKER_RETRY_DELAY_SECONDS=1.0

# Entry logic
MIN_ENTRY_SCORE=50
ENABLE_FALLBACK_ENTRY=true
ENABLE_SIGNAL_EXITS=true
EXIT_ON_DOWNTREND=true
FALLBACK_MIN_SCORE=40
FALLBACK_MAX_RSI=80
FORCE_FILL_SLOTS=true
FORCE_FILL_MIN_SCORE=30

# Exit logic
ATR_STOP_MULT=1.5
ATR_TP_MULT=2.0
MAX_HOLD_SECONDS=300

# Hard risk guardrails (0 disables)
MAX_DAILY_LOSS_PCT=1.5
MAX_BUYS_PER_HOUR=12
LOSS_STREAK_PAUSE_THRESHOLD=3
LOSS_STREAK_PAUSE_SECONDS=1800

# Indicators / timeframe
RSI_PERIOD=14
SMA_PERIOD_SHORT=20
SMA_PERIOD_LONG=50
OHLCV_TIMEFRAME=1h

# Legacy params (currently not used for exit decisions)
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10

# LLM model
USE_ML_MODEL=false
MODEL_PATH=./model/fine_tuned_trading_model
ML_MIN_CONFIDENCE=0.5

# CatBoost model
USE_TABULAR_MODEL=true
TABULAR_MODEL_PATH=./model/catboost_trading_model
TABULAR_MIN_CONFIDENCE=0.45
TABULAR_BLOCK_ON_SELL=true
TABULAR_SELL_BLOCK_MIN_PROBA=0.55
AUTO_TUNE_TABULAR_CONFIDENCE=true
AUTO_TUNE_LOOKBACK_TRADES=200
AUTO_TUNE_THRESHOLD_MIN=0.40
AUTO_TUNE_THRESHOLD_MAX=0.75
AUTO_TUNE_THRESHOLD_STEP=0.01
AUTO_TUNE_MIN_TRADES=3
AUTO_TUNE_MAX_DELTA=0.02
AUTO_TUNE_COOLDOWN_MINUTES=60
AUTO_TUNE_STATE_FILE=auto_tune_state.json

# Performance / trade journal
PERFORMANCE_LOG_ENABLED=true
PERFORMANCE_LOG_FILE=trade_journal.csv
PERFORMANCE_REPORT_EVERY=1

# AutoResearch bridge – Fear & Greed Index fetcher (no API key required)
# The fetch_research_signal.py script is run by the research-signal.timer on
# the Pi every hour.  In development you can run it manually:
#   python3 scripts/fetch_research_signal.py
TABULAR_RESEARCH_SIGNAL_PATH=./data/research_signal_latest.json
AUTORESEARCH_ENABLED=true
AUTORESEARCH_REQUIRED=false
AUTORESEARCH_REPO_PATH=
AUTORESEARCH_CMD=python3 /opt/trading_2/scripts/fetch_research_signal.py --output /opt/trading_2/data/research_signal_latest.json
AUTORESEARCH_SOURCE_PATH=
AUTORESEARCH_OUTPUT_PATH=./data/research_signal_latest.json
AUTORESEARCH_MAX_AGE_MINUTES=180
AUTORESEARCH_ALLOW_STALE=false
AUTORESEARCH_WRITE_NEUTRAL_FALLBACK=true
AUTORESEARCH_PRECHECK=true
AUTORESEARCH_PRECHECK_DRY_RUN=false
AUTORESEARCH_PRECHECK_TIMEOUT_SEC=90
AUTORESEARCH_STRICT_ALLOW_MAINTENANCE_FALLBACK=false
AUTORESEARCH_MAINTENANCE_EXIT_CODE=4

# Optional JSON status export for monitoring
STATUS_JSON_ENABLED=false
STATUS_JSON_FILE=./results/scorecards/latest_status.json

# Optional Prometheus textfile export for node_exporter textfile collector
STATUS_PROM_ENABLED=false
STATUS_PROM_FILE=./results/scorecards/latest_status.prom
