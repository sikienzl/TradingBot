# Conservative small-account profile for paper trading on Kraken market data.
# Intended for very small accounts or validation runs where capital preservation
# matters more than trade frequency.
#
# Usage:
#   cp .env.small_account.example .env
#   # optionally set DRY_RUN=false only after validating the profile

# Kraken API credentials
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Safe default: paper mode until validated
DRY_RUN=true
SIMULATE_DATA=false

# Execution cadence
CHECK_INTERVAL=20
MAX_OPEN_TRADES=1
TICKER_BATCH_SIZE=60
TICKER_FETCH_RETRIES=3
TICKER_RETRY_DELAY_SECONDS=1.5

# Position sizing
TRADE_AMOUNT=8
MIN_TRADE_AMOUNT=8
ALLOW_PARTIAL_TRADES=false
CASH_RESERVE_PCT=0.10

# Market focus
MIN_VOLUME_BASE=300000
TOP_N_FOR_ANALYSIS=8
EXCLUDED_COINS=USDC,USDT,EURT,DAI,TUSD,USDP,FDUSD,USDE,ZEC,TAO

# Entry logic: slightly stricter to reduce churn on marginal setups
MIN_ENTRY_SCORE=65
ENABLE_FALLBACK_ENTRY=true
FALLBACK_MIN_SCORE=60
FALLBACK_MAX_RSI=65
FORCE_FILL_SLOTS=false
FORCE_FILL_MIN_SCORE=40
ENTRY_REQUIRE_PRICE_ABOVE_EMA20=false
ENTRY_MOMENTUM_FILTER_ENABLED=true
ENTRY_MIN_RET_3=-0.017

# Reentry / pacing
REENTRY_COOLDOWN_SECONDS=1020
REENTRY_DYNAMIC_ENABLED=true
REENTRY_COOLDOWN_MIN_SECONDS=300
REENTRY_COOLDOWN_MAX_SECONDS=1320
REENTRY_VOLATILITY_LOW_ATR_PCT=0.008
REENTRY_VOLATILITY_HIGH_ATR_PCT=0.018
REENTRY_COOLDOWN_MULT_LOW_VOL=0.70
REENTRY_COOLDOWN_MULT_MID_VOL=1.00
REENTRY_COOLDOWN_MULT_HIGH_VOL=1.30

# Exit logic
ENABLE_SIGNAL_EXITS=true
EXIT_ON_DOWNTREND=true
ATR_STOP_MULT=1.2
TRAILING_STOP_ATR_MULT=1.1
MAX_HOLD_SECONDS=480
PARTIAL_TAKE_PROFIT_ENABLED=true
PARTIAL_TAKE_PROFIT_ATR_MULT=0.8
PARTIAL_TAKE_PROFIT_FRACTION=0.5
PARTIAL_TAKE_PROFIT_REMAINDER_MAX_HOLD_SECONDS=180
PARTIAL_TAKE_PROFIT_EXIT_ON_WEAK_SIGNAL=true

# Hard risk guardrails
MAX_DAILY_LOSS_PCT=0.8
MAX_BUYS_PER_HOUR=3
LOSS_STREAK_PAUSE_THRESHOLD=2
LOSS_STREAK_PAUSE_SECONDS=7200

# Model gate
USE_TABULAR_MODEL=true
TABULAR_MODEL_PATH=./model/catboost_trading_model
TABULAR_MIN_CONFIDENCE=0.58
TABULAR_BUY_MIN_CONFIDENCE=0.60
TABULAR_BLOCK_ON_SELL=true
TABULAR_SELL_BLOCK_MIN_PROBA=0.55
AUTO_TUNE_TABULAR_CONFIDENCE=false

# Simulate AI recommendations only: visible in logs, never applied live
AI_COPILOT_MODEL=gpt-5.4
AI_COPILOT_ENABLED=true
AI_COPILOT_SHADOW_MODE=true

# Performance log
PERFORMANCE_LOG_ENABLED=true
PERFORMANCE_LOG_FILE=trade_journal.csv
PERFORMANCE_REPORT_EVERY=1