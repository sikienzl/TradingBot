# Safe simulation profile (no real orders)
# Usage:
#   set -a; source .env.simulation.example; set +a
#   ./.venv/bin/python trading_bot.py

# Always simulation mode
DRY_RUN=true
SIMULATE_DATA=true

# Faster loop + more opportunities
CHECK_INTERVAL=5
MAX_OPEN_TRADES=4
TRADE_AMOUNT=10
MIN_TRADE_AMOUNT=3

# Use tabular model (if available), disable LLM runtime complexity
USE_TABULAR_MODEL=true
USE_ML_MODEL=false
TABULAR_MODEL_PATH=./model/catboost_trading_model
TABULAR_MIN_CONFIDENCE=0.50
TABULAR_BLOCK_ON_SELL=true
TABULAR_SELL_BLOCK_MIN_PROBA=0.55

# More permissive entry/exit behavior for simulation testing
MIN_ENTRY_SCORE=45
ENABLE_FALLBACK_ENTRY=true
ENABLE_SIGNAL_EXITS=true
EXIT_ON_DOWNTREND=true
FORCE_FILL_SLOTS=true
FALLBACK_MIN_SCORE=35
FALLBACK_MAX_RSI=72
FORCE_FILL_MIN_SCORE=30
MAX_HOLD_SECONDS=300

# Extra risk limits during simulation (relaxed for faster testing)
MAX_DAILY_LOSS_PCT=0
MAX_BUYS_PER_HOUR=12
LOSS_STREAK_PAUSE_THRESHOLD=0
LOSS_STREAK_PAUSE_SECONDS=60

# Keep logging local and explicit
PERFORMANCE_LOG_ENABLED=true
PERFORMANCE_LOG_FILE=trade_journal.csv
PERFORMANCE_REPORT_EVERY=1

# AutoResearch optional in simulation
AUTORESEARCH_ENABLED=false
