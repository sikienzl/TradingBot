# Aggressive paper-trading profile with active AI copilot and AutoResearch.
# Intended for short-term simulation runs where faster growth is prioritized
# over conservative drawdown control.
#
# Usage:
#   cp .env.aggressive_ai_autoresearch.example .env
#   # keep DRY_RUN=true for simulation-only operation

# Kraken API credentials
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Simulation on live Kraken market data
DRY_RUN=true
SIMULATE_DATA=false

# Faster opportunity capture
CHECK_INTERVAL=20
MAX_OPEN_TRADES=2
EXCHANGE_TIMEOUT_MS=15000
TICKER_BATCH_SIZE=60
TICKER_FETCH_RETRIES=3
TICKER_RETRY_DELAY_SECONDS=1.5
OHLCV_FETCH_RETRIES=1
OHLCV_RETRY_DELAY_SECONDS=1.0
SLOW_ANALYSIS_WARNING_SECONDS=8

# Position sizing
TRADE_AMOUNT=10
MIN_TRADE_AMOUNT=5
ALLOW_PARTIAL_TRADES=true
CASH_RESERVE_PCT=0.02

# Market focus
MIN_VOLUME_BASE=300000
TOP_N_FOR_ANALYSIS=12
EXCLUDED_COINS=USDC,USDT,EURT,EURC,DAI,TUSD,USDP,FDUSD,USDE,ZEC,TAO,LTC,PAXG,BILL

# Entry logic: slightly more permissive for faster simulated growth
# Pi validation on 2026-05-16 confirmed that ETH downtrend-reversal entries
# can still occur under this profile and that the fast-exit path closes flat
# reversal trades quickly instead of letting them linger.
MIN_ENTRY_SCORE=62
ENABLE_FALLBACK_ENTRY=true
FALLBACK_MIN_SCORE=40
FALLBACK_MAX_RSI=68
FORCE_FILL_SLOTS=true
FORCE_FILL_MIN_SCORE=40
DOWNTREND_REVERSAL_ENTRY_ENABLED=true
DOWNTREND_REVERSAL_MAX_RSI=20
DOWNTREND_REVERSAL_MIN_BUY_PROBA=0.22
DOWNTREND_REVERSAL_MAX_SELL_PROBA=0.30
DOWNTREND_REVERSAL_MIN_PROBA_EDGE=0.07
DOWNTREND_REVERSAL_FAST_EXIT_ENABLED=true
DOWNTREND_REVERSAL_FAST_EXIT_SECONDS=120
DOWNTREND_REVERSAL_FLAT_MAX_PROFIT_PCT=0.10
DOWNTREND_REVERSAL_MAX_HOLD_SECONDS=240
UPTREND_ENTRY_GATE_ENABLED=true
UPTREND_ENTRY_MAX_RSI=72
UPTREND_ENTRY_MIN_BUY_PROBA=0.24
UPTREND_ENTRY_MAX_SELL_PROBA=0.34
UPTREND_ENTRY_MIN_PROBA_EDGE=-0.05
UPTREND_RULES_FAST_EXIT_ENABLED=true
UPTREND_RULES_FAST_EXIT_SECONDS=120
UPTREND_RULES_FLAT_MAX_PROFIT_PCT=0.08
UPTREND_RULES_MAX_HOLD_SECONDS=300
ENTRY_REQUIRE_PRICE_ABOVE_EMA20=false
ENTRY_MOMENTUM_FILTER_ENABLED=true
ENTRY_MIN_RET_3=-0.020

# Reentry / pacing
REENTRY_COOLDOWN_SECONDS=600
REENTRY_DYNAMIC_ENABLED=true
REENTRY_COOLDOWN_MIN_SECONDS=300
REENTRY_COOLDOWN_MAX_SECONDS=900
REENTRY_VOLATILITY_LOW_ATR_PCT=0.008
REENTRY_VOLATILITY_HIGH_ATR_PCT=0.018
REENTRY_COOLDOWN_MULT_LOW_VOL=0.70
REENTRY_COOLDOWN_MULT_MID_VOL=1.00
REENTRY_COOLDOWN_MULT_HIGH_VOL=1.20

# Exit logic: allow winners a bit more room than the conservative profile
ENABLE_SIGNAL_EXITS=true
EXIT_ON_DOWNTREND=false
ATR_STOP_MULT=1.2
TRAILING_STOP_ATR_MULT=1.0
MAX_HOLD_SECONDS=720
PARTIAL_TAKE_PROFIT_ENABLED=true
PARTIAL_TAKE_PROFIT_ATR_MULT=0.8
PARTIAL_TAKE_PROFIT_FRACTION=0.5
PARTIAL_TAKE_PROFIT_REMAINDER_MAX_HOLD_SECONDS=240
PARTIAL_TAKE_PROFIT_EXIT_ON_WEAK_SIGNAL=true

# Hard risk guardrails: relaxed compared to small-account conservative mode
# Keep the default hourly buy cap at 4 for normal operation. A temporary bump to
# 8 was useful for live validation, but should remain a short-lived test lever.
MAX_DAILY_LOSS_PCT=1.5
MAX_BUYS_PER_HOUR=4
LOSS_STREAK_PAUSE_THRESHOLD=3
LOSS_STREAK_PAUSE_SECONDS=3600

# Model gate
USE_TABULAR_MODEL=true
TABULAR_MODEL_PATH=./model/catboost_trading_model
TABULAR_MIN_CONFIDENCE=0.58
TABULAR_BUY_MIN_CONFIDENCE=0.55
TABULAR_SOURCE_GATE_ENABLED=false
TABULAR_BLOCK_ON_SELL=true
TABULAR_SELL_BLOCK_MIN_PROBA=0.55
AUTO_TUNE_TABULAR_CONFIDENCE=false

# Active AI copilot in DRY_RUN mode: suggestions are actually applied
AI_COPILOT_MODEL=gpt-5.4
AI_COPILOT_ENABLED=true
AI_COPILOT_SHADOW_MODE=true
AI_COPILOT_INTERVAL_MINUTES=31
AI_COPILOT_MAX_CALLS_PER_DAY=36
AI_COPILOT_MAX_CALLS_PER_MONTH=720
AI_COPILOT_MAX_BUDGET_USD_PER_MONTH=5.0
AI_COPILOT_MIN_ENTRY_SCORE_MIN=58
AI_COPILOT_MIN_ENTRY_SCORE_MAX=68
AI_COPILOT_REENTRY_COOLDOWN_MIN=300
AI_COPILOT_REENTRY_COOLDOWN_MAX=900
AI_COPILOT_TABULAR_BUY_CONF_MIN=0.55
AI_COPILOT_TABULAR_BUY_CONF_MAX=0.62

# AutoResearch bridge and model input
TABULAR_RESEARCH_SIGNAL_PATH=./data/research_signal_latest.json
AUTORESEARCH_ENABLED=true
AUTORESEARCH_REQUIRED=false
AUTORESEARCH_REPO_PATH=
AUTORESEARCH_CMD=python3 scripts/fetch_research_signal.py --output ./data/research_signal_latest.json
AUTORESEARCH_SOURCE_PATH=
AUTORESEARCH_OUTPUT_PATH=./data/research_signal_latest.json
AUTORESEARCH_MAX_AGE_MINUTES=120
AUTORESEARCH_ALLOW_STALE=false
AUTORESEARCH_WRITE_NEUTRAL_FALLBACK=true
AUTORESEARCH_PRECHECK=true
AUTORESEARCH_PRECHECK_DRY_RUN=false
AUTORESEARCH_PRECHECK_TIMEOUT_SEC=90
AUTORESEARCH_STRICT_ALLOW_MAINTENANCE_FALLBACK=false
AUTORESEARCH_MAINTENANCE_EXIT_CODE=4

# Research providers used by scripts/fetch_research_signal.py
RESEARCH_PROVIDERS=fng,news
RESEARCH_FNG_WEIGHT=1.0
RESEARCH_NEWS_WEIGHT=0.6
RESEARCH_NEWS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://www.theblock.co/rss.xml
RESEARCH_NEWS_LOOKBACK_HOURS=24
RESEARCH_NEWS_MAX_ITEMS_PER_FEED=30

# Performance log
PERFORMANCE_LOG_ENABLED=true
PERFORMANCE_LOG_FILE=trade_journal.csv
PERFORMANCE_REPORT_EVERY=1