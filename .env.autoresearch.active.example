# Optional overlay template for REAL AutoResearch execution.
# Use this after you know repo path and start command.
# Usage:
#   cp .env.live.example .env
#   cat .env.autoresearch.active.example >> .env
#   nano .env   # fill placeholders below

# Model input path used by trading_bot.py / predict_catboost.py
TABULAR_RESEARCH_SIGNAL_PATH=./data/research_signal_latest.json

# AutoResearch bridge settings (strict mode)
AUTORESEARCH_ENABLED=true
AUTORESEARCH_REQUIRED=true
AUTORESEARCH_REPO_PATH=./external/autoresearch

# Set exactly ONE command variant below for your repo layout.
# Python repo variant A (entry script):
# AUTORESEARCH_CMD=./external/autoresearch/.venv/bin/python main.py --output ./data/research_signal_raw.json

# Python repo variant B (module entrypoint):
# AUTORESEARCH_CMD=./external/autoresearch/.venv/bin/python -m autoresearch --output ./data/research_signal_raw.json

# Node repo variant A (npm script):
# AUTORESEARCH_CMD=npm run research -- --output ./data/research_signal_raw.json

# Node repo variant B (direct node entry):
# AUTORESEARCH_CMD=node index.js --output ./data/research_signal_raw.json

# Active command (edit this line):
AUTORESEARCH_CMD=./external/autoresearch/.venv/bin/python main.py --output ./data/research_signal_raw.json
AUTORESEARCH_SOURCE_PATH=./data/research_signal_raw.json
AUTORESEARCH_OUTPUT_PATH=./data/research_signal_latest.json
AUTORESEARCH_MAX_AGE_MINUTES=120
AUTORESEARCH_ALLOW_STALE=false
AUTORESEARCH_WRITE_NEUTRAL_FALLBACK=false
AUTORESEARCH_PRECHECK=true
AUTORESEARCH_PRECHECK_DRY_RUN=true
AUTORESEARCH_PRECHECK_TIMEOUT_SEC=90
AUTORESEARCH_STRICT_ALLOW_MAINTENANCE_FALLBACK=false
AUTORESEARCH_MAINTENANCE_EXIT_CODE=4

# Optional JSON status export for monitoring
STATUS_JSON_ENABLED=false
STATUS_JSON_FILE=./results/scorecards/latest_status.json

# Optional Prometheus textfile export for node_exporter textfile collector
STATUS_PROM_ENABLED=false
STATUS_PROM_FILE=./results/scorecards/latest_status.prom

# Optional static reason (only used if fallback is enabled)
AUTORESEARCH_FALLBACK_REASON=AutoResearch execution failed
